---
import { dateFormatter } from "@utils/general";
import { Icon } from "astro-icon/components";
import JourneyIcon from "@components/TypeIcon.astro";
import { Image } from "astro:assets";
import { type CollectionEntry } from "astro:content";
import authors from "src/authors.json";

interface Props {
  journey: CollectionEntry<"posts">;
}

const { journey } = Astro.props;
const idParts = journey.id.split("/");
const journeyId = idParts[idParts.length - 1];
const author = authors.find((a) => a.id === journey.data.author);
---

<li class={journey.data.type}>
  <a
    href={new URL(
      `${import.meta.env.BASE_URL}/journey/${journeyId}`,
      Astro.url,
    )}
    class="group decoration-none block w-70 border-2 border-line bg-bg/50 p-2 backdrop-blur-md backdrop-filter transition-colors duration-300 select-none visited:text-fg-inactive hover:border-primary hover:bg-bg-2 focus:border-line focus:outline-none active:border-primary active:bg-primary active:text-bg dark:border-line-dark dark:bg-bg-dark/50 dark:visited:text-fg-inactive-dark dark:hover:border-bg-3-dark dark:hover:bg-bg-2-dark"
  >
    <h2
      class="mr-2 text-center font-serif text-2xl font-bold tracking-tight uppercase font-stretch-ultra-condensed group-hover:underline"
    >
      {journey.data.title}
    </h2>
    <div class="mx-auto my-2 size-max border-2 border-line p-1">
      <Image
        src={journey.data.image}
        alt={journey.data.alt}
        width={256}
        height={256}
        class="h-40 w-60 rounded-sm object-cover sepia transition-all group-hover:sepia-50"
        loading="eager"
      />
    </div>
    <div class="text-center font-serif">
      <div class="flex justify-center gap-2">
        <JourneyIcon typeId={journey.data.type} />
        <span>·</span>
        {dateFormatter(journey.data.date, Astro.currentLocale)}
      </div>
      <div>
        {author?.name}
        {
          journey.data.travelers > 1
            ? `+ ${journey.data.travelers - 1} weitere(r)`
            : ""
        }
      </div>
    </div>
  </a>
</li>
