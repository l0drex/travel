---
import type {
  GetStaticPaths,
  InferGetStaticParamsType,
  InferGetStaticPropsType,
} from "astro";
import {
  getCollection,
  getEntry,
  render,
  type CollectionEntry,
} from "astro:content";
import Layout from "@layouts/BaseLayout.astro";
import MapView from "@components/track/MapView.vue";
import ElevationGraph from "@components/track/ElevationGraph.vue";
import authors from "src/authors.json";
import {
  JourneyTypeId,
  journeyTypes,
  StatId,
  type VisitedCountry,
} from "@utils/types";
import JourneyType from "@components/TypeIcon.astro";
import { dateFormatter } from "@utils/general";
import { getImage } from "astro:assets";
import MarkdownContent from "@components/MarkdownContent.astro";
import Button from "@components/Button.astro";
import TitleNav from "@components/TitlesNav.astro";
import twconfig from "tailwind.config.mjs";
import TrackStats from "@components/track/TrackStats.astro";
import { addCalculatedStats, getVisitedCountries } from "@utils/geoJson";
import Flags from "@components/Flags.astro";
import { Icon } from "astro-icon/components";

export const getStaticPaths = (async () => {
  const posts: CollectionEntry<"posts">[] = await getCollection("posts");

  return posts.map((entry) => {
    const idParts = entry.id.split("/");
    const journeyId = idParts[idParts.length - 1];

    return {
      params: { journey: journeyId.replace(/.md$/, "") },
      props: { entry },
    };
  });
}) satisfies GetStaticPaths;

type Params = InferGetStaticParamsType<typeof getStaticPaths>;
type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { entry } = Astro.props;
const { Content, headings } = await render(entry);

const geoJson = await getEntry(entry.data.gpx);
const author = authors.find((a) => a.id === entry.data.author);
if (author == null) {
  throw new Error("No author found for this journey!");
}
const journeyType = journeyTypes[entry.data.type].name;

const jsDate: Date = entry.data.date;
const machineDate = jsDate.toISOString();
const humanDate = dateFormatter(jsDate, Astro.currentLocale);

const ogImage = await getImage({
  src: entry.data.image,
  width: 1200,
  height: 630,
  format: "webp",
});

type StatsType = Partial<Record<StatId, number>>;

let stats: StatsType = {
  [StatId.days]: Math.max(headings.length, 1),
  ...entry.data.stats,
};

if (entry.data.type !== JourneyTypeId.roadtrip) {
  // get relevant stats for bike and hiking journeys
  addCalculatedStats(stats, geoJson.data.geoJson);
}

const isCollection = entry.data.type === JourneyTypeId.roadtrip;

const typeSet = new Set<JourneyTypeId>();
typeSet.add(entry.data.type);

const countries = getVisitedCountries(geoJson.data.geoJson).map(
  (c) =>
    ({
      country: c,
      type: typeSet,
    }) as VisitedCountry,
);

function getAuthorUrl(fedi: string) {
  const [_1, user, domain] = fedi.split("@");
  return `https://${domain}/@${user}`;
}
---

<Layout
  title={`${entry.data.title} – ${journeyType} von ${author.name}`}
  light={twconfig.theme.extend.colors.bg["2"].DEFAULT}
  dark={twconfig.theme.extend.colors.bg["2"].dark}
>
  <Fragment slot="meta">
    <meta property="og:type" content="article" />
    <meta property="article:section" content="travel" />
    <meta property="article:section" content={entry.data.type} />
    <meta property="article:tag" content="travel" />
    <meta property="article:tag" content={entry.data.type} />

    <meta name="date" content={machineDate} />
    <meta property="article:published_time" content={machineDate} />

    <meta name="author" content={author.name} />
    <meta name="fediverse:creator" content={author.fediverse} />
    <meta property="article:author" content={author.name} />

    <meta name="description" content={entry.data.description} />
    <meta property="og:description" content={entry.data.description} />

    <meta property="og:image" content={ogImage.src} />
    <meta property="og:image:width" content={`${ogImage.options.width}`} />
    <meta property="og:image:height" content={`${ogImage.options.height}`} />
    <meta property="og:image:format" content={ogImage.options.format} />
    <meta property="og:image:alt" content={entry.data.alt} />
  </Fragment>

  <div class="pt-8"></div>

  <h1
    class="mb-4 text-center font-serif text-4xl font-bold tracking-tight font-stretch-condensed sm:text-5xl md:mt-0"
  >
    {entry.data.title}
  </h1>
  <div class="mb-4 text-center align-baseline font-serif text-2xl">
    <div class="flex justify-center gap-2">
      {(<JourneyType typeId={entry.data.type} />)}
      <span>·</span>
      <time datetime={jsDate.toISOString()}>{humanDate}</time>
    </div>
    <div>
      <a
        href={getAuthorUrl(author.fediverse)}
        class="hover:underline"
        target="_blank">{author?.name}</a
      >
      {
        entry.data.travelers > 1
          ? `+ ${entry.data.travelers - 1} weitere(r)`
          : ""
      }
    </div>
  </div>

  <Flags countries={countries} />

  <section class="mx-auto my-8 max-w-5xl px-4">
    {
      // we wrap vue components in a static div with a fixed height to prevent layout shifts.
      // collections only show the elevation graph occasionally,
      // therefore we cannot prevent the layout shift
    }
    <div class="mb-2 flex w-full justify-between align-baseline">
      <h2 class="py-1 font-serif text-xl font-bold">Tourdetails</h2>
      <Button href={`../gpx/${entry.data.gpx.id}.gpx`}>
        <Icon name="material-symbols:download" slot="icon" />
        GPX Datei
      </Button>
    </div>

    <div class="min-h-101">
      <MapView
        client:only="vue"
        geoJson={geoJson.data.geoJson}
        height={400}
        isBig={true}
        mapKey="BigMapIntro"
      />
    </div>
    <div class={isCollection ? "" : "min-h-37.5"}>
      <ElevationGraph
        client:only="vue"
        geoJson={geoJson.data.geoJson}
        isCollection={isCollection}
      />
    </div>
    <TrackStats stats={stats} />
  </section>

  <hr class="mx-auto w-xs border border-line" />

  <MarkdownContent>
    <Content />
  </MarkdownContent>

  <nav
    slot="aside"
    class="sticky top-0 hidden h-screen w-max max-w-full flex-col items-center justify-between overflow-y-auto border-r-2 border-line px-5 py-10 md:flex dark:border-line-dark dark:bg-bg-2-dark"
  >
    <Button href={import.meta.env.BASE_URL}>
      <Icon name="material-symbols:chevron-left" slot="icon" />
      Zurück zur Übersicht
    </Button>

    <TitleNav headings={headings} />

    <div class="min-h-[204px] w-full">
      <MapView
        client:only="vue"
        geoJson={geoJson.data.geoJson}
        height={200}
        isBig={false}
        mapKey="SmallMapNavBar"
      />
    </div>

    <Button href={Astro.url}>
      <Icon name="material-symbols:keyboard-arrow-up" slot="icon" />
      Zurück nach oben
    </Button>
  </nav>
</Layout>

<script>
  // update the hash of the url to the current heading
  function updateHash() {
    let visible: Element | null = null;
    const headers = document.querySelectorAll("article h1, article h2");

    for (const header of headers) {
      const pos = header.getBoundingClientRect();

      if (pos.top > 0 && pos.bottom <= window.innerHeight / 2) {
        visible = header;
        break;
      }
    }

    if (visible != null) {
      console.debug(`New section ${visible.textContent} reached`);

      // just style the nav bar, no change in url here
      // avoids unwanted scrolling done by browser

      history.pushState({}, "", `#${visible.id}`);

      // dispatch event to update other elements
      const event = new CustomEvent("silenthashchange");
      window.dispatchEvent(event);
    }
  }

  updateHash();
  document
    .querySelector("main")!
    .parentNode!.addEventListener("scrollend", updateHash);
</script>
