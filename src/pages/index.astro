---
import { getCollection, getEntry } from "astro:content";
import type { CollectionEntry } from "astro:content";
import Layout from "@layouts/BaseLayout.astro";
import EarthOverview from "@components/earth/EarthOverview.vue";
import TravelEntry from "@components/TravelEntry.astro";
import { type Journey, JourneyTypeId, type VisitedCountry } from "@utils/types";
import { coordAll, lineString, simplify } from "@turf/turf";
import authors from "src/authors.json";
import { type CountryData } from "country-codes-list";
import { getVisitedCountries } from "../utils/geoJson";
import Flags from "@components/Flags.astro";
import Button from "@components/Button.astro";
import TypeIcon from "@components/TypeIcon.astro";

const posts: CollectionEntry<"posts">[] = (await getCollection("posts")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const journeys: Journey[] = [];
const countries = new Array<VisitedCountry>();

for (let p of posts) {
  const entry = await getEntry(p.data.gpx);
  const geoJson = entry!.data.geoJson;

  let points = coordAll(geoJson);
  if (points.length > 1) {
    points = simplify(lineString(coordAll(geoJson)), { tolerance: 0.2 })
      .geometry.coordinates;
  }

  function fromPoint(p: number[]): [number, number] {
    return [p[1], p[0]];
  }

  if (p.data.type === JourneyTypeId.roadtrip) {
    journeys.push({
      points: [fromPoint(points[0])],
      type: p.data.type,
    });
  } else {
    journeys.push({
      points: points.map(fromPoint),
      type: p.data.type,
    });
  }

  getVisitedCountries(geoJson).forEach((c) => {
    let existing = countries.find((c1) => c1.country === c);
    if (!existing) {
      const type = new Set<JourneyTypeId>();
      type.add(p.data.type);
      countries.push({
        country: c,
        type,
      });
      return;
    }
    existing.type.add(p.data.type);
  });
}

const mainAuthor = authors[0].name;

const existingJourneyTypes = new Set<JourneyTypeId>();
posts.forEach((p) => existingJourneyTypes.add(p.data.type));
---

<Layout title={`Reiseblog von ${mainAuthor}`}>
  <EarthOverview
    client:only="vue"
    journeys={journeys}
    countries={countries}
    slot="background"
  />

  <h1
    class="mx-5 mt-12 mb-6 text-center font-serif text-5xl font-extrabold text-primary font-stretch-condensed sm:text-6xl"
    lang="en"
  >
    Discover my Adventures!
  </h1>
  <Flags countries={Array.from(countries)} />

  {
    /* If there is more than 1 type of journeys, show buttons to filter them */
    existingJourneyTypes.size > 1 && (
      <div class="mx-auto my-4 flex w-min justify-center gap-2">
        <Button href="?">Alle Reisen</Button>
        {existingJourneyTypes.has(JourneyTypeId.bike) && (
          <Button href={`?type=${JourneyTypeId.bike}`}>
            <TypeIcon typeId={JourneyTypeId.bike} />
          </Button>
        )}
        {existingJourneyTypes.has(JourneyTypeId.roadtrip) && (
          <Button href={`?type=${JourneyTypeId.roadtrip}`}>
            <TypeIcon typeId={JourneyTypeId.roadtrip} />
          </Button>
        )}
        {existingJourneyTypes.has(JourneyTypeId.hiking) && (
          <Button href={`?type=${JourneyTypeId.hiking}`}>
            <TypeIcon typeId={JourneyTypeId.hiking} />
          </Button>
        )}
      </div>
    )
  }

  <div
    class="mb-10 flex flex-col place-content-center items-center overflow-y-auto"
  >
    <ul
      id="blogs"
      class="grid w-max grid-cols-1 gap-8 md:grid-cols-2 xl:grid-cols-3"
    >
      {posts.map((p) => <TravelEntry journey={p} />)}
    </ul>
  </div>
</Layout>

<script>
  import { filterElements, getSelectedType } from "@utils/filterByType.ts";
  import TailwindConfig from "../../tailwind.config.mts";

  // highlight active button
  const selectedType = getSelectedType();
  const showAll = selectedType == "all";
  const hrefString = showAll ? "?" : `?type=${selectedType}`;
  const activeButton = document.querySelector<HTMLLinkElement>(
    `a[href='${hrefString}']`,
  )!;
  activeButton.style!.borderColor = TailwindConfig.theme.extend.colors.primary;
  activeButton.style!.backgroundColor =
    TailwindConfig.theme.extend.colors.primary;
  activeButton.style!.color = TailwindConfig.theme.extend.colors.fg.dark;

  const blogEntries = document.getElementById("blogs");

  if (blogEntries == null) {
    throw new Error("Blogs container was not found");
  }

  filterElements(blogEntries);
</script>
